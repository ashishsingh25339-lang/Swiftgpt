import React, { useState, useEffect, useRef } from 'react';
import { 
  Plus, 
  Menu, 
  Send, 
  Zap, 
  Loader2,
  Cpu as CpuIcon,
  Fingerprint,
  Image as ImageIcon,
  Mic,
  X,
  LayoutGrid,
  Code2,
  BarChart3,
  Dna,
  Settings,
  History
} from 'lucide-react';

const App = () => {
  const [isBooting, setIsBooting] = useState(true);
  const [bootStatus, setBootStatus] = useState("Initializing Core...");
  const [isSidebarOpen, setIsSidebarOpen] = useState(false);
  const [messages, setMessages] = useState([]);
  const [input, setInput] = useState('');
  const [selectedImage, setSelectedImage] = useState(null);
  const [isLoading, setIsLoading] = useState(false);
  
  const actionCards = [
    { id: 1, title: 'Architectural Design', icon: <LayoutGrid size={20} />, color: 'blue' },
    { id: 2, title: 'Code Optimization', icon: <Code2 size={20} />, color: 'indigo' },
    { id: 3, title: 'Market Insights', icon: <BarChart3 size={20} />, color: 'cyan' },
    { id: 4, title: 'Neural Sync', icon: <Dna size={20} />, color: 'blue' },
  ];

  const messagesEndRef = useRef(null);
  const fileInputRef = useRef(null);

  useEffect(() => {
    const statusMessages = ["Neural Link Syncing...", "Calibrating Mobile UI...", "Core v3.0 Online."];
    let current = 0;
    const interval = setInterval(() => {
      if (current < statusMessages.length) {
        setBootStatus(statusMessages[current]);
        current++;
      }
    }, 800);
    const timer = setTimeout(() => setIsBooting(false), 3000);
    return () => { clearTimeout(timer); clearInterval(interval); };
  }, []);

  useEffect(() => {
    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
  }, [messages]);

  const handleSend = async (e) => {
    e.preventDefault();
    if ((!input.trim() && !selectedImage) || isLoading) return;
    const userMsg = input.trim();
    const currentImg = selectedImage;
    setMessages(prev => [...prev, { role: 'user', content: userMsg, image: currentImg }]);
    setInput('');
    setSelectedImage(null);
    setIsLoading(true);

    try {
      const apiKey = ""; 
      const response = await fetch(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{
              role: "user",
              parts: [
                ...(currentImg ? [{ inlineData: { mimeType: "image/png", data: currentImg.split(',')[1] } }] : []),
                { text: userMsg || "System analysis requested." }
              ]
            }]
          })
        }
      );
      const data = await response.json();
      const aiResponse = data.candidates?.[0]?.content?.parts?.[0]?.text || "Communication relay severed.";
      setMessages(prev => [...prev, { role: 'assistant', content: aiResponse }]);
    } catch (error) {
      setMessages(prev => [...prev, { role: 'assistant', content: "Neural sync error." }]);
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <div className="flex h-screen w-full bg-[#020205] text-white font-sans overflow-hidden relative">
      
      {/* Boot Overlay */}
      {isBooting && (
        <div className="fixed inset-0 z-[100] bg-[#020205] flex flex-col items-center justify-center p-6">
          <div className="relative flex flex-col items-center animate-in zoom-in duration-500">
            <div className="w-20 h-20 bg-blue-600 rounded-[2rem] flex items-center justify-center shadow-[0_0_50px_rgba(37,99,235,0.4)] animate-logo-master">
               <Zap size={40} className="text-white fill-current animate-zap-shock" />
            </div>
            <h1 className="mt-8 text-2xl font-black tracking-[0.3em] uppercase italic">Swift<span className="text-blue-500">GPT</span></h1>
            <p className="mt-4 text-[10px] font-bold text-blue-100/30 uppercase tracking-[0.4em]">{bootStatus}</p>
          </div>
        </div>
      )}

      {/* Sidebar Overlay for Mobile */}
      {isSidebarOpen && (
        <div className="fixed inset-0 bg-black/60 backdrop-blur-sm z-[60] lg:hidden" onClick={() => setIsSidebarOpen(false)} />
      )}

      {/* Sidebar Content */}
      <aside className={`fixed lg:static inset-y-0 left-0 z-[70] w-72 bg-[#08080c] border-r border-white/5 transition-transform duration-300 transform ${isSidebarOpen ? 'translate-x-0' : '-translate-x-full lg:translate-x-0'} flex flex-col`}>
        <div className="p-6 border-b border-white/5 flex items-center justify-between">
          <div className="flex items-center gap-3">
             <div className="w-8 h-8 bg-blue-600 rounded-xl flex items-center justify-center">
               <Zap size={16} className="text-white fill-current" />
             </div>
             <span className="text-sm font-black italic uppercase tracking-tighter">SwiftGPT</span>
          </div>
          <button onClick={() => setIsSidebarOpen(false)} className="lg:hidden p-2 text-gray-500"><X size={20} /></button>
        </div>
        
        <div className="flex-1 overflow-y-auto p-4 space-y-6">
           <button onClick={() => {setMessages([]); setIsSidebarOpen(false);}} className="w-full py-3.5 bg-blue-600 hover:bg-blue-700 transition-all rounded-2xl font-black text-[11px] uppercase tracking-widest flex items-center justify-center gap-2 shadow-xl shadow-blue-900/20">
              <Plus size={16} /> NEW THREAD
           </button>
           
           <div className="space-y-1">
             <p className="text-[9px] font-black text-gray-700 uppercase tracking-[0.3em] mb-4 px-2 flex items-center gap-2">
               <History size={10} /> History Banks
             </p>
             {['Project Alpha', 'Neural Debug', 'Code Optimization'].map((item, i) => (
               <button key={i} className="flex items-center gap-3 w-full p-3.5 hover:bg-white/5 rounded-2xl group transition-all text-left">
                 <div className="w-1.5 h-1.5 rounded-full bg-gray-800 group-hover:bg-blue-500 transition-colors"></div>
                 <span className="text-[11px] font-bold text-gray-500 group-hover:text-gray-200 truncate uppercase tracking-widest">{item}</span>
               </button>
             ))}
           </div>
        </div>

        <div className="p-4 border-t border-white/5">
           <button className="flex items-center gap-3 w-full p-3 text-gray-500 hover:text-white transition-colors">
              <Settings size={18} />
              <span className="text-[11px] font-bold uppercase tracking-widest">Core Settings</span>
           </button>
        </div>
      </aside>

      {/* Main Container */}
      <main className="flex-1 flex flex-col relative min-w-0">
        
        {/* Top Header */}
        <header className="h-16 px-4 md:px-8 border-b border-white/5 flex items-center justify-between bg-black/40 backdrop-blur-xl shrink-0 z-50">
          <div className="flex items-center gap-4">
             <button onClick={() => setIsSidebarOpen(true)} className="lg:hidden p-2 hover:bg-white/5 rounded-xl transition-all">
                <Menu size={20} className="text-gray-400" />
             </button>
             <div className="hidden sm:flex items-center gap-2 px-3 py-1 bg-blue-500/5 border border-blue-500/10 rounded-full">
                <div className="w-1.5 h-1.5 bg-blue-500 rounded-full animate-pulse"></div>
                <span className="text-[9px] font-black text-blue-500 uppercase tracking-widest">Neural Link v3.0</span>
             </div>
          </div>
          
          <div className="flex items-center gap-3">
             <div className="text-right hidden xs:block">
                <p className="text-[9px] font-black text-gray-600 uppercase tracking-tighter">Premium User</p>
                <p className="text-[11px] font-bold text-white tracking-tight">ALEXANDER SWIFT</p>
             </div>
             <div className="w-9 h-9 rounded-xl bg-gradient-to-br from-gray-800 to-gray-900 border border-white/10 flex items-center justify-center font-black text-blue-500 text-xs">
                AS
             </div>
          </div>
        </header>

        {/* Chat / Dashboard View */}
        <div className="flex-1 overflow-y-auto custom-scrollbar relative">
          {messages.length === 0 ? (
            <div className="min-h-full flex flex-col items-center justify-center p-6 text-center max-w-4xl mx-auto">
              <div className="relative mb-8 group">
                <div className="absolute inset-0 bg-blue-600/20 blur-3xl rounded-full group-hover:bg-blue-600/30 transition-all duration-700"></div>
                <h1 className="text-4xl md:text-6xl font-black text-white tracking-tighter italic relative z-10 animate-in slide-in-from-top-10 duration-700">
                  Neural Interface.
                </h1>
              </div>

              <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 w-full mt-8 animate-in slide-in-from-bottom-10 duration-1000">
                {actionCards.map(card => (
                  <button key={card.id} className="group p-6 rounded-[2rem] bg-[#08080c] border border-white/5 hover:border-blue-500/30 hover:bg-blue-600/5 transition-all duration-300 text-left relative overflow-hidden active:scale-95">
                    <div className="absolute top-0 right-0 p-3 opacity-0 group-hover:opacity-100 transition-opacity">
                      <Plus size={14} className="text-blue-500" />
                    </div>
                    <div className="p-3 bg-white/5 rounded-2xl w-fit mb-4 group-hover:scale-110 group-hover:bg-blue-600 transition-all duration-300 group-hover:text-white text-gray-400">
                      {card.icon}
                    </div>
                    <p className="text-[11px] font-black text-gray-400 group-hover:text-white uppercase tracking-widest leading-tight">{card.title}</p>
                  </button>
                ))}
              </div>
            </div>
          ) : (
            <div className="max-w-3xl mx-auto p-4 md:p-8 space-y-8 pb-40">
              {messages.map((msg, i) => (
                <div key={i} className={`flex ${msg.role === 'user' ? 'justify-end' : 'justify-start'} animate-in fade-in slide-in-from-bottom-4`}>
                  <div className={`max-w-[90%] md:max-w-[80%] space-y-3`}>
                    {msg.image && (
                      <div className="relative group">
                        <img src={msg.image} className="max-w-full rounded-3xl border border-white/10 shadow-2xl transition-transform duration-500 group-hover:scale-[1.02]" alt="attachment" />
                      </div>
                    )}
                    <div className={`p-5 md:p-7 rounded-[2.2rem] text-[15px] leading-relaxed shadow-2xl ${
                      msg.role === 'user' 
                      ? 'bg-blue-600 text-white rounded-tr-none border-none' 
                      : 'bg-[#0a0a0f] border border-white/5 text-gray-200 rounded-tl-none'
                    }`}>
                      {msg.content}
                    </div>
                  </div>
                </div>
              ))}
              {isLoading && (
                <div className="flex justify-start">
                  <div className="bg-[#0a0a0f] border border-white/5 p-4 rounded-2xl flex items-center gap-3">
                    <Loader2 size={16} className="text-blue-500 animate-spin" />
                    <span className="text-[11px] font-black uppercase tracking-widest text-gray-500">Syncing...</span>
                  </div>
                </div>
              )}
              <div ref={messagesEndRef} />
            </div>
          )}
        </div>

        {/* Input Controller */}
        <div className="absolute bottom-0 left-0 right-0 p-4 md:p-8 bg-gradient-to-t from-[#020205] via-[#020205]/90 to-transparent z-[40]">
           <div className="max-w-3xl mx-auto relative">
              
              {selectedImage && (
                <div className="absolute -top-20 left-2 animate-in zoom-in duration-300">
                  <div className="relative group">
                    <img src={selectedImage} className="w-16 h-16 object-cover rounded-2xl border-2 border-blue-600 shadow-2xl transition-transform group-hover:scale-105" alt="preview" />
                    <button onClick={() => setSelectedImage(null)} className="absolute -top-2 -right-2 bg-red-500 text-white rounded-full p-1.5 shadow-xl hover:scale-110 active:scale-90"><X size={10} /></button>
                  </div>
                </div>
              )}

              <form onSubmit={handleSend} className="flex items-center bg-[#0d0d12]/80 backdrop-blur-3xl border border-white/10 rounded-[2.5rem] px-2 py-2 focus-within:border-blue-500/50 shadow-2xl transition-all group">
                <div className="flex items-center gap-1">
                  <button type="button" onClick={() => fileInputRef.current?.click()} className={`p-3.5 rounded-full transition-all ${selectedImage ? 'text-blue-500 bg-blue-500/10' : 'text-gray-600 hover:text-blue-400 hover:bg-white/5'}`}>
                    <ImageIcon size={20} />
                  </button>
                  <button type="button" className="p-3.5 text-gray-600 hover:text-blue-400 hover:bg-white/5 rounded-full transition-all hidden sm:block">
                    <Mic size={20} />
                  </button>
                </div>
                
                <input 
                  type="text"
                  value={input}
                  onChange={(e) => setInput(e.target.value)}
                  placeholder="Analyze core data..."
                  className="flex-1 bg-transparent py-3.5 px-4 text-[15px] text-white focus:outline-none placeholder:text-gray-800"
                />
                
                <button disabled={(!input.trim() && !selectedImage) || isLoading} className="p-4 rounded-full bg-blue-600 text-white shadow-2xl hover:bg-blue-700 active:scale-90 transition-all disabled:opacity-20 group-hover:shadow-blue-500/20">
                  {isLoading ? <Loader2 size={20} className="animate-spin" /> : <Send size={20} />}
                </button>
              </form>
              <p className="mt-4 text-[8px] md:text-[9px] text-center text-gray-700 font-bold uppercase tracking-[0.4em] opacity-40">Neural Link Sequence Active : All Systems Online</p>
           </div>
        </div>

        <input type="file" accept="image/*" ref={fileInputRef} className="hidden" onChange={(e) => {
          const file = e.target.files[0];
          if (file) {
            const reader = new FileReader();
            reader.onload = (f) => setSelectedImage(f.target.result);
            reader.readAsDataURL(file);
          }
        }} />
      </main>

      <style>{`
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #1a1a24; border-radius: 10px; }
        
        @keyframes laser-scan { 0% { top: -100%; } 100% { top: 100%; } }
        @keyframes logo-master { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.1) rotate(5deg); } }
        @keyframes zap-shock { 0%, 100% { filter: brightness(1) drop-shadow(0 0 0px #fff); } 98% { filter: brightness(2) drop-shadow(0 0 15px #3b82f6); } }
        
        .animate-laser-scan { animation: laser-scan 2s infinite ease-in-out; }
        .animate-logo-master { animation: logo-master 3s infinite ease-in-out; }
        .animate-zap-shock { animation: zap-shock 3s infinite; }
      `}</style>
    </div>
  );
};

export default App;

